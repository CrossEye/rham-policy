caption: Outline Dashboard
caption-title: yes
title: $:/plugins/crosseye/outline/dashboard/view
type: text/vnd.tiddlywiki

\whitespace trim

<$let pol={{{ [{$:/state/outline/dashboard/policy}] }}}>
  <% if [<pol>!is[blank]] %>
    <$transclude $variable="outline-dashboard" pol=<<pol>> />
  <% else %>
    No outline selected.
  <% endif %>
</$let>
